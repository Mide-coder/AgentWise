{
  "name": "@agentwise/api",
  "version": "0.1.0",
  "description": "AgentWise REST API — Goal Engine backend",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "node --import tsx/esm src/server.ts",
    "dev:watch": "node --watch --import tsx/esm src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentwise/sdk": "workspace:*",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "xrpl": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "tsx": "^4.15.0",
    "vitest": "^1.6.0",
    "typescript": "^5.4.5"
  }
}
