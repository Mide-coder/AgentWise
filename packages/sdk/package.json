    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "sql.js": "^1.14.1",
    "uuid": "^9.0.1",
    "xrpl": "^3.0.0"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
