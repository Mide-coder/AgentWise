{
  "name": "@agentwise/sdk",
  "version": "0.1.0",
  "description": "AgentWise core SDK – Yellow Nitrolite state channels + XRPL settlement",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
