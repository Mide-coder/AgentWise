# ── Network ──────────────────────────────────────────────
# "testnet" or "mainnet"
NEXT_PUBLIC_NETWORK=testnet

# ── XRPL ─────────────────────────────────────────────────
NEXT_PUBLIC_XRPL_NODE_TESTNET=wss://s.altnet.rippletest.net:51233
NEXT_PUBLIC_XRPL_NODE_MAINNET=wss://xrplcluster.com

# RLUSD issuer address (testnet)
NEXT_PUBLIC_RLUSD_ISSUER_TESTNET=rHb9CJAWyB4rj91VRWn96DkukG4bwdtyTh
# RLUSD issuer address (mainnet — fill before mainnet deploy)
NEXT_PUBLIC_RLUSD_ISSUER_MAINNET=

# ── Yellow / Nitrolite ───────────────────────────────────
YELLOW_SDK_API_KEY=your_yellow_sdk_api_key_here
YELLOW_BROKER_URL=wss://broker.sandbox.yellow.com
YELLOW_NETWORK=sandbox

# ── Backend API ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── AI Agent (Python) ───────────────────────────────────
AGENT_XRPL_SEED=sEdTxxxxxxxxxxxxxxxxxxxxxxxxxx
AGENT_GOAL_ID=your_goal_id_here
AGENT_TOP_UP_THRESHOLD_RLUSD=10
AGENT_POLL_INTERVAL_SECONDS=30
